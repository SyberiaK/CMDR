{
  "schemaVersion": 1,
  "id": "custom-music-discs-records",
  "version": "${version}",

  "name": "CMDR - Custom Music Discs Records",
  "description": "Manage your music discs records faster and easier than ever before.",
  "authors": [
    "SyberiaK"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/SyberiaK/CMDR",
    "issues": "https://github.com/SyberiaK/CMDR/issues"
  },

  "license": "MIT",
  "icon": "assets/custom-music-discs-records/icon.png",

  "environment": "client",
  "entrypoints": {
    "client": [
      "me.syberiak.cmdr.CMDRLoader"
    ],
    "modmenu": [
      "me.syberiak.cmdr.config.ModMenuIntegration"
    ]
  },
  "mixins": [
    "custom-music-discs-records.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.14.6",
    "fabric": "*",
    "minecraft": "~1.18.2",
    "java": ">=17",
    "modmenu": "*"
